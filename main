def get_referrals_list(user_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT referred_id, created_at FROM referrals WHERE referrer_id = ? ORDER BY created_at DESC", (user_id,))
    r = c.fetchall()
    conn.close()
    return [{"id": ref[0], "date": ref[1]} for ref in r]

def get_all_users():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT user_id, username, first_name, has_subscription, total_paid, is_banned, subscription_type, checked_channels, referral_count, subscription_end FROM users")
    r = c.fetchall()
    conn.close()
    return [{"user_id": u[0], "username": u[1] or "нет", "first_name": u[2] or "нет", 
             "active": bool(u[3]), "total_paid": u[4] or 0, "is_banned": bool(u[5]),
             "subscription_type": u[6] or "BETA", "checked_channels": bool(u[7]), 
             "referral_count": u[8] or 0, "subscription_end": u[9]} for u in r]

def get_user_info(user_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT username, first_name, total_paid, trial_used, is_banned, subscription_type, checked_channels, referral_count, subscription_end FROM users WHERE user_id = ?", (user_id,))
    r = c.fetchone()
    conn.close()
    if r:
        return {"username": r[0], "first_name": r[1], "total_paid": r[2] or 0, 
                "trial_used": bool(r[3]), "is_banned": bool(r[4]),
                "subscription_type": r[5] or "BETA", "checked_channels": bool(r[6]), 
                "referral_count": r[7] or 0, "subscription_end": r[8]}
    return None

def get_remaining_days(user_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT subscription_end FROM users WHERE user_id = ?", (user_id,))
    r = c.fetchone()
    conn.close()
    if r and r[0]:
        end = datetime.fromisoformat(r[0])
        return max(0, (end - datetime.now()).days)
    return 0

def save_payment(user_id, days, amount, payment_type="ruble", charge_id=None):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("INSERT INTO payments (user_id, amount, days, status, created_at, payment_type, charge_id) VALUES (?, ?, ?, ?, ?, ?, ?)",
              (user_id, amount, days, "pending", datetime.now().isoformat(), payment_type, charge_id))
    conn.commit()
    pid = c.lastrowid
    conn.close()
    return pid

def update_payment_status(payment_id, status, charge_id=None):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    if charge_id:
        c.execute("UPDATE payments SET status = ?, charge_id = ? WHERE id = ?", (status, charge_id, payment_id))
    else:
        c.execute("UPDATE payments SET status = ? WHERE id = ?", (status, payment_id))
    conn.commit()
    conn.close()

def get_pending_payments():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT id, user_id, amount, days, payment_type FROM payments WHERE status = 'pending'")
    r = c.fetchall()
    conn.close()
    return [{"id": p[0], "user_id": p[1], "amount": p[2], "days": p[3], "payment_type": p[4]} for p in r]

def get_stats():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM users")
    total = c.fetchone()[0]
    c.execute("SELECT COUNT(*) FROM users WHERE has_subscription = 1 AND is_banned = 0")
    active = c.fetchone()[0]
    c.execute("SELECT SUM(total_paid) FROM users")
    revenue = c.fetchone()[0] or 0
    c.execute("SELECT COUNT(*) FROM sessions")
    accounts = c.fetchone()[0]
    c.execute("SELECT COUNT(*) FROM groups")
    groups = c.fetchone()[0]
    c.execute("SELECT COUNT(*) FROM payments WHERE status = 'pending'")
    pending = c.fetchone()[0]
    conn.close()
    return {"total": total, "active": active, "revenue": revenue, "accounts": accounts, 
            "groups": groups, "pending": pending}


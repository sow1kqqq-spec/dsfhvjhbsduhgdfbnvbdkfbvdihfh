@telethon_bot.on(events.CallbackQuery(data=b"add_account"))
async def add_account_cb(event):
    uid = event.sender_id
    
    await event.respond(
        "📱 Для добавления аккаунта, введите номер телефона в формате:\n"
        "`+7XXXXXXXXXX` или `+380XXXXXXXXX`\n\n"
        "📌 Например: `+79161234567`\n\n"

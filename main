def add_to_history(user_id, group_name, message):
    message_hash = hashlib.md5(message.encode()).hexdigest()
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("INSERT INTO send_history (user_id, group_name, sent_at, message_text, message_hash) VALUES (?, ?, ?, ?, ?)",
              (user_id, group_name, datetime.now().isoformat(), message[:200], message_hash))
    conn.commit()
    conn.close()

def is_message_sent(user_id, message, group_id):
    message_hash = hashlib.md5(message.encode()).hexdigest()
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    try:
        c.execute("SELECT id FROM send_history WHERE user_id = ? AND message_hash = ? AND group_name LIKE ?", 
                  (user_id, message_hash, f"%{str(group_id)}%"))
        result = c.fetchone()
        conn.close()
        return result is not None
    except:
        conn.close()
        return False

def get_history(user_id, limit=10):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT group_name, sent_at, message_text FROM send_history WHERE user_id = ? ORDER BY sent_at DESC LIMIT ?", (user_id, limit))
    r = c.fetchall()
    conn.close()
    return r

def format_number(num):
    return f"{num:,}".replace(",", " ")

def get_group_link(username):
    if username and username.startswith('@'):
        return f"https://t.me/{username[1:]}"
    elif username:
        return f"https://t.me/{username}"
    return username

def add_signature(text, user_id):
    sub_type = get_subscription_type(user_id)
    if sub_type == "BETA":
        return f"{text}{SIGNATURE}"
    return text

# ============ ФУНКЦИИ БОТА ============
async def auto_subscribe_to_channels(user_id, client):
    try:
        required = get_required_channels()
        sponsors = get_sponsors()
        all_channels = required + sponsors
        
        subscribed = []
        for channel in all_channels:
            try:
                channel_clean = channel.replace('@', '').strip()
                
                try:
                    entity = await client.get_entity(channel)
                except:
                    try:
                        entity = await client.get_entity(f"@{channel_clean}")
                    except:
                        continue
                
                try:
                    participant = await client(GetParticipantRequest(entity, 'me'))
                    subscribed.append(channel)
                    continue
                except:
                    pass
                
                try:
                    await client(JoinChannelRequest(entity))
                    subscribed.append(channel)
                    print(f"✅ Подписались на {channel}")
                    await asyncio.sleep(1)
                except Exception as e:
                    print(f"❌ Не удалось подписаться на {channel}: {e}")
                    
            except Exception as e:
                print(f"❌ Ошибка с {channel}: {e}")
        
        return subscribed
    except Exception as e:
        print(f"❌ Ошибка авто подписки: {e}")
        return []

async def process_message_queue():
    while True:
        try:
            task = await message_queue.get()
            user_id = task['user_id']
            groups = task['groups']
            text = task['text']
            image_data = task.get('image_data')
            
            session = get_session(user_id)
            if not session:
                continue
            
            try:
                client = TelegramClient(StringSession(session), API_ID, API_HASH)
                await client.connect()
                
                await auto_subscribe_to_channels(user_id, client)
                
                final_text = add_signature(text, user_id)
                
                for group in groups:
                    try:
                        group_id = int(group['id'])
                        
                        if is_message_sent(user_id, final_text, group_id):
                            print(f"⏭️ Пропуск дубликата в {group['title']}")
                            continue
                        
                        try:
                            entity = await client.get_entity(group_id)
                        except:
                            dialogs = await client.get_dialogs()
                            entity = None
                            for dialog in dialogs:
                                if dialog.entity.id == group_id:
                                    entity = dialog.entity
                                    break
                        
                        if not entity:
                            continue
                        
                        if image_data:
                            await client.send_file(entity, image_data, caption=final_text)
                        else:
                            await client.send_message(entity, final_text)
                        
                        add_to_history(user_id, group['title'] or group['username'], final_text)
                        print(f"✅ Отправлено в {group['title']}")
                        
                        await asyncio.sleep(0.3)
                        
                    except FloodWaitError as e:
                        wait_time = e.seconds
                        print(f"⏳ Flood wait {wait_time} сек для {group['title']}")
                        await asyncio.sleep(wait_time)
                    except Exception as e:
                        print(f"❌ Ошибка в {group['title']}: {str(e)[:100]}")
                        await asyncio.sleep(0.2)
                
                await client.disconnect()
                
            except Exception as e:
                print(f"❌ Ошибка в очереди: {e}")
            
            message_queue.task_done()
            
        except Exception as e:
            print(f"❌ Ошибка обработки очереди: {e}")
            await asyncio.sleep(1)

async def send_message_to_groups(user_id, groups, text, image_data=None, is_scheduled=False):
    if not check_subscription(user_id):
        return {"success": 0, "fails": 0, "failed_groups": ["Подписка истекла"]}
    
    session = get_session(user_id)
    if not session:
        return {"success": 0, "fails": 0, "failed_groups": ["Нет аккаунта"]}
    
    await message_queue.put({
        'user_id': user_id,
        'groups': groups,
        'text': text,
        'image_data': image_data
    })
    
    return {"success": len(groups), "fails": 0, "failed_groups": []}

# ============ КЛАВИАТУРЫ ============
def get_main_menu(user_id):
    is_admin = user_id in ADMIN_IDS
    has_sub = check_subscription(user_id)
    buttons = []
    
    if has_sub:
        days_left = get_remaining_days(user_id)
        buttons.append([Button.inline(f"🌟 Подписка (осталось {days_left} дн.)", b"subscription_info")])
    else:
        buttons.append([Button.inline("🌟 Купить подписку", b"buy_subscription")])
    
    buttons.append([Button.inline("➕ Добавить аккаунт", b"add_account"), Button.inline("👤 Мои аккаунты", b"my_accounts")])
    buttons.append([Button.inline("📋 Добавить все группы", b"add_all_groups"), Button.inline("👥 Мои группы", b"my_groups")])
    buttons.append([Button.inline("📨 Рассылка", b"send_message"), Button.inline("📊 История", b"show_history")])
    buttons.append([Button.inline("ℹ️ Инфо", b"info"), Button.inline("🔗 Реферальная система", b"referral")])
    
    if is_admin:
        buttons.append([Button.inline("👑 Админ панель", b"admin_panel")])
    
    return buttons

def get_payment_keyboard():
    builder = InlineKeyboardBuilder()
    builder.button(text="⭐ Оплатить", pay=True)
    return builder.as_markup()

async def show_group_selection(uid, event):
    groups = get_user_groups(uid)
    
    if uid not in selected_groups:
        selected_groups[uid] = [g['id'] for g in groups]
    
    selected = selected_groups.get(uid, [])
    
    buttons = []
    for group in groups:
        is_selected = group['id'] in selected
        icon = "✅" if is_selected else "❌"
        title = group['title'] or group['username'] or f"Группа {group['id']}"
        if len(title) > 25:
            title = title[:22] + "..."
        buttons.append([Button.inline(f"{icon} {title}", f"toggle_group_{group['id']}")])
    
    buttons.append([
        Button.inline("✅ Выбрать все", b"select_all_groups"),
        Button.inline("❌ Снять все", b"deselect_all_groups")
    ])
    buttons.append([Button.inline("📨 Отправить в выбранные", b"send_selected_groups")])
    buttons.append([Button.inline("🔙 Назад", b"back_to_main")])
    
    total_selected = len(selected)
    total_groups = len(groups)
    
    try:
        await event.edit(
            f"📨 **ВЫБЕРИТЕ ГРУППЫ ДЛЯ РАССЫЛКИ**\n\n"
            f"👥 Всего групп: {total_groups}\n"
            f"✅ Выбрано: {total_selected}\n"
            f"❌ Не выбрано: {total_groups - total_selected}\n\n"
            f"🟢 **✅** - группа выбрана (будет отправка)\n"
            f"🔴 **❌** - группа не выбрана (пропуск)\n\n"
            f"📢 Подпись добавляется только для BETA подписки\n\n"
            f"💡 Нажмите на группу, чтобы переключить статус",
            buttons=buttons
        )
    except MessageNotModifiedError:
        pass
    
    user_states[uid] = {"action": "selecting_groups"}

# ============ ОБРАБОТЧИКИ TELEGRAM ============
@dp.pre_checkout_query()
async def pre_checkout_handler(pre_checkout_query: PreCheckoutQuery):
    await pre_checkout_query.answer(ok=True)

@dp.message(F.successful_payment)
async def success_payment_handler(message: types.Message):
    uid = message.from_user.id
    payment = message.successful_payment
    
    try:
        payload = payment.invoice_payload
        days = int(payload.split("_")[1])
    except:
        days = 30
    
    payment_id = save_payment(uid, days, payment.total_amount, "star", payment.telegram_payment_charge_id)
    update_payment_status(payment_id, "confirmed", payment.telegram_payment_charge_id)
    extend_subscription(uid, days, payment.total_amount, "star", payment.telegram_payment_charge_id)
    
    await message.answer(
        f"🥳 **Оплата прошла успешно!** 🎉\n\n"
        f"🌟 Подписка активирована на {days} дней!\n"
        f"⭐ Списано: {payment.total_amount} звезд\n\n"
        f"🎉 Спасибо за покупку!"
    )

@telethon_bot.on(events.NewMessage(pattern="/start"))
async def start_cmd(event):
    uid = event.sender_id
    user = await event.get_sender()
    
    referrer_id = None
    if event.text and "ref_" in event.text:
        try:
            referrer_id = int(event.text.split("ref_")[1].split()[0])
            if referrer_id == uid:
                referrer_id = None
        except:
            pass
    
    is_new = register_user(uid, user.username, user.first_name, referrer_id)
    days = get_remaining_days(uid)
    sub_type = get_subscription_type(uid)
    
    mark_channels_checked(uid)
    
    try:
        channel_msg = await telethon_bot.send_message(
            uid,
            "🔍 | наш новостной канал",
            buttons=[[Button.url("📢 Подписаться", CHANNEL_LINK)]]
        )
        
        try:
            await telethon_bot.pin_message(uid, channel_msg, notify=False)
            print(f"📌 Закреплено сообщение для {uid}")
        except Exception as e:
            print(f"⚠️ Не удалось закрепить сообщение для {uid}: {e}")
    except Exception as e:
        print(f"❌ Ошибка отправки сообщения с каналом для {uid}: {e}")
    
    if is_new and referrer_id:
        await telethon_bot.send_message(
            uid,
            f"👋 Добро пожаловать!\n\n"
            f"🔧 Для начала работы добавьте аккаунт и группы!\n"
            f"📦 Подписка: {sub_type}\n"
            f"📅 Осталось: {days} дн.\n"
            f"🎁 Вы зарегистрировались по реферальной ссылке и получили 1 день подписки!",
            buttons=get_main_menu(uid)
        )
    elif is_new:
        await telethon_bot.send_message(
            uid,
            f"👋 Добро пожаловать!\n\n"
            f"🔧 Для начала работы добавьте аккаунт и группы!\n"
            f"📦 Подписка: {sub_type}\n"
            f"📅 Осталось: {days} дн.\n"
            f"🔗 Используйте реферальную ссылку для получения бонусов!",
            buttons=get_main_menu(uid)
        )
    else:
        if check_subscription(uid):
            await telethon_bot.send_message(
                uid,
                f"👋 Главное меню\n"
                f"📦 Подписка: {sub_type}\n"
                f"📅 Осталось: {days} дн.",
                buttons=get_main_menu(uid)
            )
        else:
            await telethon_bot.send_message(
                uid,
                f"👋 Главное меню\n"
                f"📦 Подписка: {sub_type}\n"
                f"📅 Осталось: {days} дн.\n\n"
                f"💡 Для работы добавьте аккаунт и купите подписку!",
                buttons=get_main_menu(uid)
            )

@telethon_bot.on(events.CallbackQuery(data=b"check_subscription"))

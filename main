@telethon_bot.on(events.CallbackQuery(data=b"cancel_add_account"))
async def cancel_add_account_cb(event):
    uid = event.sender_id
    if uid in phone_waiting:
        del phone_waiting[uid]
    if uid in user_clients:
        try:
            await user_clients[uid].disconnect()
        except:
            pass
        del user_clients[uid]
    if uid in user_phones:
        del user_phones[uid]
    if uid in code_waiting:
        del code_waiting[uid]
    if uid in user_temp_codes:
        del user_temp_codes[uid]
    await event.respond("❌ Добавление аккаунта отменено", buttons=get_main_menu(uid))

@telethon_bot.on(events.NewMessage(func=lambda e: e.sender_id in phone_waiting))
async def process_phone_input(event):
    uid = event.sender_id
    
    if not event.text:
        await event.respond("❌ Отправьте номер текстом")
        return
    
    phone = event.text.strip()
    phone = re.sub(r'[^\d+]', '', phone)
    
    if not phone.startswith('+'):
        phone = '+' + phone
    
    if len(phone) < 7:
        await event.respond("❌ Слишком короткий номер. Используйте формат: `+79161234567`")
        return
    
    if phone in user_clients:
        try:
            await user_clients[uid].disconnect()
        except:
            pass
        del user_clients[uid]
    
    client = TelegramClient(StringSession(), API_ID, API_HASH, connection_retries=3)
    user_clients[uid] = client
    user_phones[uid] = phone
    
    try:
        await client.connect()
        
        if await client.is_user_authorized():
            me = await client.get_me()
            session_str = client.session.save()
            save_session(uid, session_str)
            
            await event.respond(f"✅ Аккаунт @{me.username or me.first_name} добавлен!\n🆔 ID: {me.id}\n\n🎁 Вам начислена подписка BETA на {FREE_TRIAL_DAYS} дня!")
            
            if not check_subscription(uid):
                activate_beta_subscription(uid)
            
            await event.respond("👋 Главное меню:", buttons=get_main_menu(uid))
            if uid in phone_waiting:
                del phone_waiting[uid]
            if uid in user_clients:
                del user_clients[uid]
            return
        
        print(f"📤 Отправка кода на номер {phone}")
        await client.send_code_request(phone)
        print(f"✅ Код отправлен")
        
        code_waiting[uid] = phone
        if uid in phone_waiting:
            del phone_waiting[uid]
        
        await event.respond(
            f"✅ Код отправлен на номер {phone[-4:]}!\n\n"
            f"📱 Введите код используя кнопки ниже:",
            buttons=[
                [Button.inline("1️⃣", b"code_1"), Button.inline("2️⃣", b"code_2"), Button.inline("3️⃣", b"code_3")],
                [Button.inline("4️⃣", b"code_4"), Button.inline("5️⃣", b"code_5"), Button.inline("6️⃣", b"code_6")],
                [Button.inline("7️⃣", b"code_7"), Button.inline("8️⃣", b"code_8"), Button.inline("9️⃣", b"code_9")],
                [Button.inline("⌫ Удалить", b"code_backspace"), Button.inline("0️⃣", b"code_0"), Button.inline("✅ Готово", b"code_done")],
                [Button.inline("🔄 Запросить код снова", b"code_resend")]
            ]
        )
        
    except PhoneNumberInvalidError:
        await event.respond("❌ Неверный номер! Проверьте формат: `+79161234567`")
        if uid in phone_waiting:
            del phone_waiting[uid]
        if uid in user_clients:
            del user_clients[uid]
        if uid in user_phones:
            del user_phones[uid]
    except PhoneNumberFloodError:
        await event.respond("⚠️ Слишком много попыток! Подождите 5-10 минут.")
        if uid in phone_waiting:
            del phone_waiting[uid]
        if uid in user_clients:
            del user_clients[uid]
        if uid in user_phones:
            del user_phones[uid]
    except FloodWaitError as e:
        wait_time = e.seconds // 60
        await event.respond(f"⚠️ Подождите {wait_time} минут ({e.seconds} сек)")
        if uid in phone_waiting:
            del phone_waiting[uid]
        if uid in user_clients:
            del user_clients[uid]
        if uid in user_phones:
            del user_phones[uid]
    except Exception as e:
        error_msg = str(e)
        print(f"❌ Ошибка: {error_msg}")
        await event.respond(f"❌ Ошибка: {error_msg[:200]}")
        if uid in phone_waiting:
            del phone_waiting[uid]
        if uid in user_clients:
            del user_clients[uid]
        if uid in user_phones:
            del user_phones[uid]

@telethon_bot.on(events.CallbackQuery(func=lambda e: e.data.startswith(b"code_")))
async def code_calculator_cb(event):
    uid = event.sender_id
    action = event.data.decode()
    
    if action == "code_resend":
        if uid not in user_phones:
            try:
                await event.answer("❌ Номер не найден. Начните заново /start", alert=True)
            except:
                pass
            return
        
        phone = user_phones[uid]
        
        if uid in user_clients:
            try:
                await user_clients[uid].disconnect()
            except:
                pass
            del user_clients[uid]
        
        client = TelegramClient(StringSession(), API_ID, API_HASH, connection_retries=3)
        try:
            await client.connect()
        except Exception as e:
            try:
                await event.answer(f"❌ Ошибка подключения: {str(e)[:30]}", alert=True)
            except:
                pass
            return
            
        user_clients[uid] = client
        
        try:
            print(f"🔄 Повторная отправка кода на {phone}")
            await client.send_code_request(phone)
            code_waiting[uid] = phone
            user_temp_codes[uid] = ""
            
            try:
                await event.edit(
                    f"✅ Код отправлен заново!\n\n"
                    f"📱 Введите код: `____`",
                    buttons=[
                        [Button.inline("1️⃣", b"code_1"), Button.inline("2️⃣", b"code_2"), Button.inline("3️⃣", b"code_3")],
                        [Button.inline("4️⃣", b"code_4"), Button.inline("5️⃣", b"code_5"), Button.inline("6️⃣", b"code_6")],
                        [Button.inline("7️⃣", b"code_7"), Button.inline("8️⃣", b"code_8"), Button.inline("9️⃣", b"code_9")],
                        [Button.inline("⌫ Удалить", b"code_backspace"), Button.inline("0️⃣", b"code_0"), Button.inline("✅ Готово", b"code_done")],
                        [Button.inline("🔄 Запросить код снова", b"code_resend")]
                    ]
                )
            except:
                await event.respond(
                    f"✅ Код отправлен заново!\n\n"
                    f"📱 Введите код: `____`",
                    buttons=[
                        [Button.inline("1️⃣", b"code_1"), Button.inline("2️⃣", b"code_2"), Button.inline("3️⃣", b"code_3")],
                        [Button.inline("4️⃣", b"code_4"), Button.inline("5️⃣", b"code_5"), Button.inline("6️⃣", b"code_6")],
                        [Button.inline("7️⃣", b"code_7"), Button.inline("8️⃣", b"code_8"), Button.inline("9️⃣", b"code_9")],
                        [Button.inline("⌫ Удалить", b"code_backspace"), Button.inline("0️⃣", b"code_0"), Button.inline("✅ Готово", b"code_done")],
                        [Button.inline("🔄 Запросить код снова", b"code_resend")]
                    ]
                )
            
            try:
                await event.answer("✅ Код отправлен!")
            except:
                pass
        except Exception as e:
            try:
                await event.answer(f"❌ Ошибка: {str(e)[:50]}", alert=True)
            except:
                pass
        return
    
    if uid not in user_temp_codes:
        user_temp_codes[uid] = ""
    
    if action == "code_backspace":
        user_temp_codes[uid] = user_temp_codes[uid][:-1]
    elif action == "code_done":
        code = user_temp_codes[uid]
        if len(code) < 5:
            try:
                await event.answer("❌ Минимум 5 цифр!", alert=True)
            except:
                pass
            return
        
        if uid not in code_waiting:
            try:
                await event.answer("❌ Сессия истекла. Нажмите 'Запросить код снова'", alert=True)
            except:
                pass
            return
        
        phone = code_waiting[uid]
        client = user_clients.get(uid)
        if not client:
            try:
                await event.answer("❌ Ошибка сессии", alert=True)
            except:
                pass
            return
        
        try:
            print(f"🔐 Вход с кодом {code} для {phone}")
            await client.sign_in(phone, code)
            session_str = client.session.save()
            save_session(uid, session_str)
            me = await client.get_me()
            
            await event.respond(f"✅ Аккаунт @{me.username or me.first_name} добавлен!\n🆔 ID: {me.id}\n\n🎁 Вам начислена подписка BETA на {FREE_TRIAL_DAYS} дня!")
            
            if not check_subscription(uid):
                activate_beta_subscription(uid)
            
            await event.respond("👋 Главное меню:", buttons=get_main_menu(uid))
            
            for key in [code_waiting, user_clients, user_temp_codes, user_phones]:
                if uid in key:
                    del key[uid]
            
            try:
                await event.answer()
            except:
                pass
            return
            
        except SessionPasswordNeededError:
            password_waiting[uid] = {"client": client, "phone": phone}
            await event.respond("🔐 Введите пароль 2FA (введите текстом):")
            if uid in user_temp_codes:
                del user_temp_codes[uid]
            try:
                await event.answer()
            except:
                pass
            return
            
        except PhoneCodeInvalidError:
            await event.respond("❌ Неверный код. Попробуйте снова:")
            user_temp_codes[uid] = ""
            try:
                await event.answer()
            except:
                pass
            return
            
        except PhoneCodeExpiredError:
            await event.respond("❌ Код истек. Нажмите 'Запросить код снова'")
            if uid in user_temp_codes:
                del user_temp_codes[uid]
            try:
                await event.answer()
            except:
                pass
            return
            
        except Exception as e:
            error_msg = str(e)
            print(f"❌ Ошибка входа: {error_msg}")
            if "phone code invalid" in error_msg.lower():
                await event.respond("❌ Неверный код. Попробуйте снова:")
                user_temp_codes[uid] = ""
            else:
                await event.respond(f"❌ Ошибка: {error_msg[:200]}")
                if uid in user_temp_codes:
                    del user_temp_codes[uid]
            try:
                await event.answer()
            except:
                pass
            return
    else:
        digit = action.split("_")[1]
        if len(user_temp_codes[uid]) < 10:
            user_temp_codes[uid] += digit
    
    current_code = user_temp_codes[uid]
    display_code = current_code if current_code else "____"
    
    try:
        await event.answer(f"Код: {display_code}", alert=False)
    except:
        pass
    
    try:
        await event.edit(
            f"✅ Введите код:\n\n"
            f"📱 Код: `{display_code}`",
            buttons=[
                [Button.inline("1️⃣", b"code_1"), Button.inline("2️⃣", b"code_2"), Button.inline("3️⃣", b"code_3")],
                [Button.inline("4️⃣", b"code_4"), Button.inline("5️⃣", b"code_5"), Button.inline("6️⃣", b"code_6")],
                [Button.inline("7️⃣", b"code_7"), Button.inline("8️⃣", b"code_8"), Button.inline("9️⃣", b"code_9")],
                [Button.inline("⌫ Удалить", b"code_backspace"), Button.inline("0️⃣", b"code_0"), Button.inline("✅ Готово", b"code_done")],
                [Button.inline("🔄 Запросить код снова", b"code_resend")]
            ]
        )
    except:
        try:
            await event.respond(
                f"✅ Введите код:\n\n"
                f"📱 Код: `{display_code}`",
                buttons=[
                    [Button.inline("1️⃣", b"code_1"), Button.inline("2️⃣", b"code_2"), Button.inline("3️⃣", b"code_3")],
                    [Button.inline("4️⃣", b"code_4"), Button.inline("5️⃣", b"code_5"), Button.inline("6️⃣", b"code_6")],
                    [Button.inline("7️⃣", b"code_7"), Button.inline("8️⃣", b"code_8"), Button.inline("9️⃣", b"code_9")],
                    [Button.inline("⌫ Удалить", b"code_backspace"), Button.inline("0️⃣", b"code_0"), Button.inline("✅ Готово", b"code_done")],
                    [Button.inline("🔄 Запросить код снова", b"code_resend")]
                ]
            )
        except:
            pass

@telethon_bot.on(events.NewMessage(func=lambda e: e.sender_id in password_waiting))
async def process_password(event):
    uid = event.sender_id
    pwd = event.text.strip()
    data = password_waiting[uid]
    client = data["client"]
    try:
        await client.sign_in(password=pwd)
        session_str = client.session.save()
        save_session(uid, session_str)
        me = await client.get_me()
        
        await event.respond(f"✅ Аккаунт @{me.username or me.first_name} добавлен!\n🆔 ID: {me.id}\n\n🎁 Вам начислена подписка BETA на {FREE_TRIAL_DAYS} дня!")
        
        if not check_subscription(uid):
            activate_beta_subscription(uid)
        
        await event.respond("👋 Главное меню:", buttons=get_main_menu(uid))
        del password_waiting[uid]
        if uid in user_clients:
            del user_clients[uid]
        if uid in user_phones:
            del user_phones[uid]
    except Exception as e:
        await event.respond(f"❌ Ошибка: {str(e)[:200]}")

@telethon_bot.on(events.CallbackQuery(data=b"my_accounts"))
async def my_accounts_cb(event):
    uid = event.sender_id
    
    session = get_session(event.sender_id)
    if not session:
        await event.respond("❌ Нет аккаунтов", buttons=get_main_menu(event.sender_id))
        return
    try:
        client = TelegramClient(StringSession(session), API_ID, API_HASH)
        await client.connect()
        me = await client.get_me()
        await client.disconnect()
        await event.respond(
            f"📱 ВАШ АККАУНТ\n\n👤 {me.first_name}\n📝 @{me.username or 'нет'}\n🆔 {me.id}",
            buttons=[[Button.inline("❌ Удалить", b"delete_account"), Button.inline("◀️ Назад", b"back_to_main")]]
        )
    except:
        await event.respond("❌ Ошибка загрузки", buttons=[[Button.inline("❌ Удалить", b"delete_account")]])

@telethon_bot.on(events.CallbackQuery(data=b"delete_account"))
async def delete_account_cb(event):
    delete_session(event.sender_id)
    clear_user_groups(event.sender_id)
    await event.respond("✅ Аккаунт и группы удалены", buttons=get_main_menu(event.sender_id))

@telethon_bot.on(events.CallbackQuery(data=b"add_all_groups"))
async def add_all_groups_cb(event):
    uid = event.sender_id
    
    if not check_subscription(uid):
        await event.respond("❌ Подписка истекла! Нажмите '🌟 Купить подписку'")
        return
    
    session = get_session(uid)
    if not session:
        await event.respond("❌ Сначала добавьте аккаунт!", buttons=get_main_menu(uid))
        return
    
    await event.respond("🔄 Загрузка групп... Подождите...")
    
    try:
        client = TelegramClient(StringSession(session), API_ID, API_HASH)
        await client.connect()
        
        await auto_subscribe_to_channels(uid, client)
        
        clear_user_groups(uid)
        mark_channels_checked(uid)
        
        dialogs = await client.get_dialogs()
        
        groups_found = 0
        channels_found = 0
        skipped = 0
        group_names = []
        channel_names = []
        
        for dialog in dialogs:
            try:
                entity = dialog.entity
                entity_type = type(entity).__name__
                name = dialog.name or "Без имени"
                
                is_group = False
                is_channel = False
                is_user = False
                is_broadcast = False
                
                try:
                    if hasattr(dialog, 'is_group') and dialog.is_group:
                        is_group = True
                    if hasattr(dialog, 'is_channel') and dialog.is_channel:
                        is_channel = True
                    if hasattr(dialog, 'is_user') and dialog.is_user:
                        is_user = True
                except:
                    pass
                
                if 'User' in entity_type:
                    is_user = True
                elif 'Chat' in entity_type:
                    is_group = True
                elif 'Channel' in entity_type:
                    try:
                        is_broadcast = getattr(entity, 'broadcast', False)
                    except:
                        is_broadcast = False
                    
                    try:
                        has_participants = hasattr(entity, 'participants_count') and entity.participants_count is not None
                    except:
                        has_participants = False
                    
                    if is_broadcast:
                        is_channel = True
                        is_group = False
                    elif has_participants:
                        is_group = True
                        is_channel = False
                    else:
                        if hasattr(dialog, 'is_channel') and dialog.is_channel:
                            is_channel = True
                            is_group = False
                        else:
                            is_group = True
                            is_channel = False
                
                if is_group and not is_user and not is_channel:
                    group_id = entity.id
                    group_name = name
                    
                    username = None
                    if hasattr(entity, 'username') and entity.username:
                        username = f"@{entity.username}"
                    
                    add_group(uid, group_id, username or group_name, group_name, "group")
                    groups_found += 1
                    
                    if username:
                        group_names.append(f"🔗 {get_group_link(username)} - {group_name}")
                    else:
                        group_names.append(f"📌 {group_name}")
                    
                    print(f"✅ Добавлена группа: {group_name}")
                elif is_channel:
                    channels_found += 1
                    channel_names.append(name)
                    print(f"⏭️ Пропущен канал: {name}")
                else:
                    skipped += 1
                    
            except Exception as e:
                skipped += 1
                print(f"⚠️ Ошибка: {e}")
        
        await client.disconnect()
        
        result_text = f"✅ Добавлены все группы!\n\n"
        result_text += f"📋 Групп: {groups_found}\n"
        result_text += f"📢 Каналов (пропущено): {channels_found}\n"
        result_text += f"⏭️ Пользователей (пропущено): {skipped}\n"
        
        if group_names:
            preview = "\n".join(group_names[:10])
            if len(group_names) > 10:
                preview += f"\n... и еще {len(group_names) - 10} групп"
            result_text += f"\n\n📌 Найденные группы:\n{preview}"
        else:
            result_text += f"\n\n❌ Группы не найдены!"
            
        if channel_names:
            channel_preview = "\n".join(channel_names[:5])
            if len(channel_names) > 5:
                channel_preview += f"\n... и еще {len(channel_names) - 5} каналов"
            result_text += f"\n\n📢 Пропущенные каналы (только группы):\n{channel_preview}"
        
        await event.respond(result_text, buttons=get_main_menu(uid))
        
    except Exception as e:
        error_msg = str(e)
        print(f"❌ Ошибка: {error_msg}")
        await event.respond(f"❌ Ошибка: {error_msg[:200]}", buttons=get_main_menu(uid))

@telethon_bot.on(events.CallbackQuery(data=b"send_message"))
async def send_message_cb(event):
    uid = event.sender_id
    
    if not check_subscription(uid):
        await event.respond("❌ Подписка истекла! Нажмите '🌟 Купить подписку'")
        return
    
    groups = get_user_groups(uid)
    if not groups:
        await event.respond("❌ Нет добавленных групп!\n\nНажмите '📋 Добавить все группы'", 
                           buttons=get_main_menu(uid))
        return
    
    await show_group_selection(uid, event)

@telethon_bot.on(events.CallbackQuery(func=lambda e: e.data.startswith(b"toggle_group_")))
async def toggle_group_cb(event):
    uid = event.sender_id
    group_id = int(event.data.decode().split("_")[2])
    
    if uid not in selected_groups:
        selected_groups[uid] = []
    
    if group_id in selected_groups[uid]:
        selected_groups[uid].remove(group_id)
        await event.answer("❌ Группа исключена из рассылки", alert=True)
    else:
        selected_groups[uid].append(group_id)
        await event.answer("✅ Группа добавлена в рассылку", alert=True)
    
    await show_group_selection(uid, event)

@telethon_bot.on(events.CallbackQuery(data=b"select_all_groups"))
async def select_all_groups_cb(event):
    uid = event.sender_id
    groups = get_user_groups(uid)
    selected_groups[uid] = [g['id'] for g in groups]
    await event.answer("✅ Выбраны все группы", alert=True)
    await show_group_selection(uid, event)

@telethon_bot.on(events.CallbackQuery(data=b"deselect_all_groups"))
async def deselect_all_groups_cb(event):
    uid = event.sender_id
    if uid not in selected_groups:
        selected_groups[uid] = []
    else:
        selected_groups[uid].clear()
    await event.answer("❌ Все группы сняты", alert=True)
    await show_group_selection(uid, event)

@telethon_bot.on(events.CallbackQuery(data=b"send_selected_groups"))
async def send_selected_groups_cb(event):
    uid = event.sender_id
    
    if uid not in selected_groups or not selected_groups[uid]:
        await event.answer("❌ Выберите хотя бы одну группу!", alert=True)
        return
    
    selected = selected_groups[uid]
    all_groups = get_user_groups(uid)
    groups_to_send = [g for g in all_groups if g['id'] in selected]
    
    if not groups_to_send:
        await event.respond("❌ Нет выбранных групп!", buttons=get_main_menu(uid))
        return
    
    user_states[uid] = {"action": "waiting_for_content", "groups": groups_to_send}
    
    selected_names = "\n".join([f"  • {g['title'] or g['username']}" for g in groups_to_send[:10]])
    if len(groups_to_send) > 10:
        selected_names += f"\n  ... и еще {len(groups_to_send) - 10} групп"
    
    await event.edit(
        f"📨 **ПОДТВЕРЖДЕНИЕ РАССЫЛКИ**\n\n"
        f"👥 Выбрано групп: {len(groups_to_send)}\n\n"
        f"📋 Список выбранных групп:\n{selected_names}\n\n"
        f"📝 Отправьте текст или изображение для рассылки\n\n"
        f"📢 Подпись добавляется только для BETA подписки",
        buttons=[[Button.inline("❌ Отмена", b"cancel_send")]]
    )

@telethon_bot.on(events.CallbackQuery(data=b"cancel_send"))
async def cancel_send_cb(event):
    uid = event.sender_id
    if uid in user_states:
        del user_states[uid]
    if uid in selected_groups:
        del selected_groups[uid]
    await event.respond("❌ Рассылка отменена", buttons=get_main_menu(event.sender_id))

@telethon_bot.on(events.NewMessage(func=lambda e: e.sender_id in user_states and user_states.get(e.sender_id, {}).get("action") == "waiting_for_content"))
async def process_send_content(event):
    uid = event.sender_id
    groups = user_states[uid].get("groups", [])
    
    if not groups:
        await event.respond("❌ Нет групп для рассылки!")
        if uid in user_states:
            del user_states[uid]
        return
    
    image_data = None
    text = ""
    
    if event.photo:
        try:
            file = await event.download_media(file=bytes)
            image_data = file
            text = event.caption or ""
            await event.respond("✅ Изображение получено!")
        except Exception as e:
            await event.respond(f"❌ Ошибка: {str(e)[:100]}")
            return
    elif event.text:
        text = event.text.strip()
        if not text:
            await event.respond("❌ Сообщение не может быть пустым!")
            return
        await event.respond(f"✅ Текст получен!")
    else:
        await event.respond("❌ Отправьте текст или изображение!")
        return
    
    user_states[uid] = {
        "action": "choose_repeat",
        "groups": groups,
        "message": text,
        "image": image_data
    }
    
    await event.respond(
        f"📨 ГОТОВО К ОТПРАВКЕ\n\n"
        f"📢 Текст:\n{text[:200] if text else '(без текста)'}...\n"
        f"🖼️ Изображение: {'✅' if image_data else '❌'}\n"
        f"👥 Групп: {len(groups)}\n\n"
        f"🔄 Выберите интервал для повтора:",
        buttons=[
            [Button.inline("⏰ Без повтора", b"repeat_0")],
            [Button.inline("🔄 Каждый час", b"repeat_1")],
            [Button.inline("🔄 Каждые 3 часа", b"repeat_3")],
            [Button.inline("🔄 Каждые 6 часов", b"repeat_6")],
            [Button.inline("🔄 Каждые 12 часов", b"repeat_12")],
            [Button.inline("🔄 Каждые 24 часа", b"repeat_24")],
            [Button.inline("❌ Отмена", b"cancel_repeat")]
        ]
    )

@telethon_bot.on(events.CallbackQuery(func=lambda e: e.data.startswith(b"repeat_")))
async def repeat_choice_cb(event):
    uid = event.sender_id
    action = event.data.decode()
    
    if uid not in user_states or user_states[uid].get("action") != "choose_repeat":
        await event.answer("❌ Сессия истекла", alert=True)
        return
    
    if action == "cancel_repeat":
        if uid in user_states:
            del user_states[uid]
        if uid in selected_groups:
            del selected_groups[uid]
        await event.respond("❌ Отправка отменена", buttons=get_main_menu(uid))
        return
    
    hours = int(action.split("_")[1])
    groups = user_states[uid].get("groups", [])
    text = user_states[uid].get("message", "")
    image_data = user_states[uid].get("image", None)
    
    if uid in user_states:
        del user_states[uid]
    if uid in selected_groups:
        del selected_groups[uid]
    
    await event.respond(f"🔄 Отправка в {len(groups)} групп...")
    
    result = await send_message_to_groups(uid, groups, text, image_data, is_scheduled=False)
    
    result_text = f"✅ РАССЫЛКА ЗАВЕРШЕНА!\n\n"
    result_text += f"✅ Успешно: {result['success']}\n"
    result_text += f"❌ Ошибок: {result['fails']}\n"
    result_text += f"👥 Групп: {len(groups)}\n"
    result_text += f"🖼️ Изображение: {'✅' if image_data else '❌'}"
    
    if result['failed_groups']:
        result_text += f"\n\n❌ Ошибки в:\n" + "\n".join(result['failed_groups'][:10])
        if len(result['failed_groups']) > 10:
            result_text += f"\n... и еще {len(result['failed_groups']) - 10}"
    
    if hours > 0:
        result_text += f"\n\n🔄 Повтор каждые {hours} часов"
        
        async def scheduled_send():
            print(f"⏰ Запланированная отправка для {uid}")
            if check_subscription(uid):
                result = await send_message_to_groups(uid, groups, text, image_data, is_scheduled=True)
                try:
                    await telethon_bot.send_message(uid, 
                        f"🔄 ЗАПЛАНИРОВАННАЯ РАССЫЛКА\n"
                        f"✅ Успешно: {result['success']}\n"
                        f"❌ Ошибок: {result['fails']}\n"
                        f"👥 Групп: {len(groups)}"
                    )
                except:
                    pass
            else:
                try:
                    await telethon_bot.send_message(uid, "❌ Подписка истекла! Рассылка отменена.")
                except:
                    pass
        
        job_id = f"{uid}_{datetime.now().timestamp()}"
        scheduler.add_job(
            scheduled_send,
            'interval',
            hours=hours,
            id=job_id,
            replace_existing=True
        )
        scheduled_jobs[job_id] = {
            "user_id": uid,
            "job_id": job_id,
            "hours": hours,
            "groups": groups,
            "message": text,
            "image": image_data
        }
        
        result_text += f"\n\n🔔 Для отмены повтора: /cancel_repeat"
    
    await event.respond(result_text, buttons=get_main_menu(uid))

@telethon_bot.on(events.NewMessage(pattern="/cancel_repeat"))
async def cancel_repeat_cmd(event):
    uid = event.sender_id
    
    canceled = 0
    for job_id, job_info in list(scheduled_jobs.items()):
        if job_info["user_id"] == uid:
            try:
                scheduler.remove_job(job_id)
                del scheduled_jobs[job_id]
                canceled += 1
            except:
                pass
    
    if canceled > 0:
        await event.respond(f"✅ Отменено {canceled} запланированных рассылок", buttons=get_main_menu(uid))
    else:
        await event.respond("❌ Нет активных запланированных рассылок", buttons=get_main_menu(uid))

@telethon_bot.on(events.CallbackQuery(func=lambda e: e.data.startswith(b"pay_")))
async def payment_cb(event):
    payment_id = int(event.data.decode().split("_")[1])
    for admin_id in ADMIN_IDS:
        try:
            await telethon_bot.send_message(admin_id, f"💰 Платеж!\n👤 {event.sender_id}\n✅ /confirm {payment_id}")
        except:
            pass
    await event.respond("✅ Заявка отправлена! Ожидайте подтверждения.")

@telethon_bot.on(events.NewMessage(pattern="/users"))
async def users_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        return
    users = get_all_users()
    if not users:
        await event.respond("Нет пользователей")
        return
    
    text = "👥 ПОЛЬЗОВАТЕЛИ\n\n"
    for u in users[:30]:
        status = "🟢" if u["active"] else "🔴"
        if u["is_banned"]:
            status = "⛔"
        
        remaining = 0
        if u["subscription_end"]:
            try:
                end = datetime.fromisoformat(u["subscription_end"])
                remaining = max(0, (end - datetime.now()).days)
            except:
                pass
        
        channels_checked = "✅" if u["checked_channels"] else "❌"
        sub_status = f"{u['subscription_type']} ({remaining} дн.)" if remaining > 0 else f"{u['subscription_type']} (🔴 истекла)"
        
        text += f"{status} `{u['user_id']}` | @{u['username']}\n"
        text += f"   📦 {sub_status}\n"
        text += f"   👥 {u['referral_count']} | {channels_checked}\n\n"
    
    if len(users) > 30:
        text += f"📊 Всего: {len(users)} пользователей. Показано 30."
    else:
        text += f"📊 Всего: {len(users)} пользователей."
    
    await event.respond(text)

@telethon_bot.on(events.NewMessage(pattern="/check (\\d+)"))
async def check_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        return
    m = re.match(r"/check (\d+)", event.text)
    if m:
        uid = int(m.group(1))
        info = get_user_info(uid)
        if info:
            days = get_remaining_days(uid)
            status = "🟢 Активна" if check_subscription(uid) else "🔴 Неактивна"
            channels_checked = "✅" if info["checked_channels"] else "❌"
            await event.respond(f"📊 Пользователь {uid}\n"
                               f"👤 {info['first_name']}\n"
                               f"📦 {info['subscription_type']}\n"
                               f"📅 {status}\n"
                               f"💰 {info['total_paid']} руб\n"
                               f"📆 Осталось: {days} дн.\n"
                               f"📢 Каналы проверены: {channels_checked}\n"
                               f"👥 Приглашений: {info['referral_count']}")
        else:
            await event.respond(f"❌ Пользователь {uid} не найден")


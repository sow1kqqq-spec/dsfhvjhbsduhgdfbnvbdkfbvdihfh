    await event.respond(text)

@telethon_bot.on(events.NewMessage(pattern="/confirm (\\d+)"))
async def confirm_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        return
    m = re.match(r"/confirm (\d+)", event.text)
    if m:
        pid = int(m.group(1))
        payments = get_pending_payments()
        payment = next((p for p in payments if p['id'] == pid), None)
        if payment:
            conn = sqlite3.connect(DB_PATH)
            c = conn.cursor()
            c.execute("UPDATE payments SET status = 'confirmed' WHERE id = ?", (pid,))
            conn.commit()
            conn.close()
            new_end = extend_subscription(payment['user_id'], payment['days'], payment['amount'], payment['payment_type'])
            await event.respond(f"✅ Платеж подтвержден!\n👤 {payment['user_id']}\n📅 {payment['days']} дн.\n📆 До {new_end.strftime('%Y-%m-%d %H:%M')}")
            try:
                await telethon_bot.send_message(payment['user_id'], f"✅ Подписка активирована на {payment['days']} дней!")
            except:
                pass
        else:
            await event.respond(f"❌ Платеж не найден")

@telethon_bot.on(events.NewMessage(pattern="/broadcast_all"))
async def broadcast_all_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        return
    msg = event.text.replace("/broadcast_all", "").strip()
    if not msg:
        await event.respond("❌ Укажите текст: /broadcast_all текст")
        return
    users = get_all_users()
    sent = 0
    await event.respond(f"📢 Рассылка {len(users)} пользователям...")
    for u in users:
        if u.get("is_banned"):
            continue
        try:
            await telethon_bot.send_message(u['user_id'], f"📢 ОБЪЯВЛЕНИЕ\n\n{msg}\n\n🤖 @{BOT_USERNAME}")
            sent += 1
            await asyncio.sleep(0.3)
        except:
            pass
    await event.respond(f"✅ Отправлено: {sent} из {len(users)}")

@telethon_bot.on(events.NewMessage(pattern="/listchats"))
async def list_chats_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        return
    
    session = get_session(event.sender_id)
    if not session:
        await event.respond("❌ Нет аккаунта")
        return
    
    try:
        client = TelegramClient(StringSession(session), API_ID, API_HASH)
        await client.connect()
        
        dialogs = await client.get_dialogs()
        text = "📋 ВСЕ ЧАТЫ\n\n"
        
        groups_found = []
        channels_found = []
        users_found = []
        
        for dialog in dialogs:
            entity = dialog.entity
            entity_type = type(entity).__name__
            name = dialog.name or "Без имени"
            
            is_group = False
            is_channel = False
            is_user = False
            is_broadcast = False
            
            try:
                if hasattr(dialog, 'is_group') and dialog.is_group:
                    is_group = True
                if hasattr(dialog, 'is_channel') and dialog.is_channel:
                    is_channel = True
                if hasattr(dialog, 'is_user') and dialog.is_user:
                    is_user = True
            except:
                pass
            
            if 'User' in entity_type:
                is_user = True
            elif 'Chat' in entity_type:
                is_group = True
            elif 'Channel' in entity_type:
                try:
                    is_broadcast = getattr(entity, 'broadcast', False)
                except:
                    is_broadcast = False
                
                try:
                    has_participants = hasattr(entity, 'participants_count') and entity.participants_count is not None
                except:
                    has_participants = False
                
                if is_broadcast:
                    is_channel = True
                    is_group = False
                elif has_participants:
                    is_group = True
                    is_channel = False
                else:
                    if hasattr(dialog, 'is_channel') and dialog.is_channel:
                        is_channel = True
                        is_group = False
                    else:
                        is_group = True
                        is_channel = False
            
            if is_group and not is_user and not is_channel:
                type_label = "👥 ГРУППА"
                groups_found.append(f"{name}")
            elif is_channel:
                type_label = "📢 КАНАЛ"
                channels_found.append(f"{name}")
            else:
                type_label = "👤 ПОЛЬЗОВАТЕЛЬ"
                users_found.append(f"{name}")
            
            if len(groups_found) + len(channels_found) + len(users_found) <= 30:
                text += f"{type_label} {name}\n"
                if is_broadcast:
                    text += f"   📢 Это канал (broadcast)\n"
                text += "\n"
        
        text += f"\n📊 СТАТИСТИКА:\n"
        text += f"👥 Групп: {len(groups_found)}\n"
        text += f"📢 Каналов: {len(channels_found)}\n"
        text += f"👤 Пользователей: {len(users_found)}\n"
        text += f"📋 Всего: {len(dialogs)}"
        
        await client.disconnect()
        await event.respond(text)
        
    except Exception as e:
        await event.respond(f"❌ Ошибка: {str(e)[:200]}")

@telethon_bot.on(events.NewMessage(pattern="/addchannel @(\\w+)"))
async def add_channel_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        await event.respond("❌ Доступ запрещен")
        return
    m = re.match(r"/addchannel (@\w+)", event.text)
    if m:
        channel = m.group(1)
        if add_required_channel(channel):
            await event.respond(f"✅ Канал {channel} добавлен в обязательные")
        else:
            await event.respond(f"⚠️ Канал {channel} уже есть в списке")

@telethon_bot.on(events.NewMessage(pattern="/removechannel @(\\w+)"))
async def remove_channel_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        await event.respond("❌ Доступ запрещен")
        return
    m = re.match(r"/removechannel (@\w+)", event.text)
    if m:
        channel = m.group(1)
        if remove_required_channel(channel):
            await event.respond(f"✅ Канал {channel} удален из обязательных")
        else:
            await event.respond(f"⚠️ Канал {channel} не найден в списке")

@telethon_bot.on(events.NewMessage(pattern="/channels"))
async def list_channels_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        await event.respond("❌ Доступ запрещен")
        return
    channels = get_required_channels()
    text = f"📢 Обязательные каналы:\n\n"
    if channels:
        text += "\n".join(channels)
    else:
        text += "Обязательные каналы не заданы"
    await event.respond(text)

# ============ ЗАПУСК БОТА ============
async def main():
    print("=" * 50)
    print("🚀 ЗАПУСК БОТА")
    print("=" * 50)
    
    init_database()
    init_sponsors()
    init_required_channels()
    
    print("🔄 Подключение Telethon...")
    await telethon_bot.start(bot_token=BOT_TOKEN)
    me = await telethon_bot.get_me()
    print(f"✅ Telethon бот @{me.username} запущен!")
    print(f"👑 Админы: {ADMIN_IDS}")
    
    print("🔄 Подключение aiogram...")
    asyncio.create_task(dp.start_polling(aiogram_bot))
    print("✅ Aiogram запущен для оплаты звездами!")
    
    asyncio.create_task(process_message_queue())
    
    print("=" * 50)
    scheduler.start()
    print("✅ Планировщик запущен")
    print("📱 БОТ РАБОТАЕТ!")
    print("=" * 50)
    
    await telethon_bot.run_until_disconnected()

def run_bot():
    """Запуск бота в отдельном потоке"""
    loop = asyncio.new_event_loop()
    asyncio.set_event_loop(loop)
    try:
        loop.run_until_complete(main())
    except Exception as e:
        print(f"❌ Ошибка в боте: {e}")
    finally:
        loop.close()

# ============ ВЕБ-ИНТЕРФЕЙС ДЛЯ ХОСТИНГА ============
@app.route('/')
def index():
    return jsonify({
        'status': 'running',
        'bot': BOT_USERNAME,
        'version': '1.0.0',
        'admin_ids': ADMIN_IDS
    })

@app.route('/health')
def health():
    return jsonify({'status': 'healthy'})

@app.route('/webhook', methods=['POST'])
def webhook():
    return jsonify({'status': 'ok'})

@app.route('/stats')
def stats():
    stats_data = get_stats()
    return jsonify(stats_data)

# ============ ТОЧКА ВХОДА ============
if __name__ == "__main__":
    # Запускаем бота в фоновом потоке
    bot_thread = threading.Thread(target=run_bot, daemon=True)
    bot_thread.start()
    
    # Запускаем Flask сервер
    port = int(os.environ.get('PORT', 8080))
    print(f"🌐 Запуск веб-сервера на порту {port}")
    app.run(host='0.0.0.0', port=port)

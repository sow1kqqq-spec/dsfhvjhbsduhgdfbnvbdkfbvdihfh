def auto_install():
    packages = ['telethon', 'apscheduler', 'loguru', 'pillow', 'aiogram']
    for package in packages:
        try:
            __import__(package)
        except ImportError:
            print(f"📦 Устанавливаем {package}...")
            os.system(f"{sys.executable} -m pip install {package} --quiet")

auto_install()


            ]
        )

@telethon_bot.on(events.CallbackQuery(data=b"referral"))
async def referral_cb(event):
    uid = event.sender_id
    
    link = get_referral_link(uid)
    count = get_referral_count(uid)
    referrals = get_referrals_list(uid)
    
    text = f"🔗 РЕФЕРАЛЬНАЯ СИСТЕМА\n\n"
    text += f"👤 Ваша реферальная ссылка:\n`{link}`\n\n"
    text += f"📊 Приглашений: {count}\n"
    text += f"🎁 Бонус: 1 день подписки вам и 1 день тому, кто перешел по ссылке\n\n"
    
    if referrals:
        text += "📋 Приглашенные пользователи:\n"
        for ref in referrals[:10]:
            text += f"└ 🆔 {ref['id']} | {ref['date'][:10]}\n"
        if len(referrals) > 10:
            text += f"... и еще {len(referrals) - 10} пользователей"
    else:
        text += "📋 У вас пока нет приглашенных пользователей"
    
    await event.respond(
        text,
        buttons=[
            [Button.inline("📤 Поделиться ссылкой", b"share_referral")],
            [Button.inline("◀️ Назад", b"back_to_main")]
        ]
    )


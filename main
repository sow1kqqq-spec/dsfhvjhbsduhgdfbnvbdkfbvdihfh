@telethon_bot.on(events.NewMessage(pattern="/podpis (\\d+) (\\d+)"))
async def give_sub_cmd(event):
    if event.sender_id not in ADMIN_IDS:
        return
    m = re.match(r"/podpis (\d+) (\d+)", event.text)
    if m:
        uid = int(m.group(1))
        days = int(m.group(2))
        
        if days >= 9999:
            amount = 750
        elif days >= 365:
            amount = 500
        elif days >= 90:
            amount = 300
        elif days >= 30:
            amount = 150
        elif days >= 7:
            amount = 50
        else:
            amount = days * 7
        
        await event.respond(
            f"📝 **Выберите тип подписки** для пользователя {uid}\n\n"
            f"📅 Дней: {days}\n"
            f"💰 Стоимость: {amount} руб\n\n"
            f"🟢 **BETA** - Стандартная подписка (с рекламой)\n"
            f"🟣 **PREMIUM** - Расширенная подписка (без рекламы)",
            buttons=[
                [Button.inline("🟢 BETA", f"sub_BETA_{uid}_{days}_{amount}")],
                [Button.inline("🟣 PREMIUM", f"sub_PREMIUM_{uid}_{days}_{amount}")],
                [Button.inline("❌ Отмена", b"cancel_subscription")]
            ]
        )

@telethon_bot.on(events.CallbackQuery(data=lambda d: d.startswith(b"sub_")))
async def subscription_type_cb(event):
    data = event.data.decode().split("_")
    if len(data) < 4:
        await event.respond("❌ Ошибка данных")
        return
    
    if data[0] == "cancel":
        await event.respond("❌ Выдача подписки отменена")
        return
    
    if data[0] == "sub":
        sub_type = data[1]
        uid = int(data[2])
        days = int(data[3])
        amount = int(data[4]) if len(data) > 4 else 0
        
        new_end = extend_subscription(uid, days, amount, "admin", None, sub_type)
        
        await event.respond(
            f"✅ Подписка выдана!\n"
            f"👤 Пользователь: {uid}\n"
            f"📅 Дней: {days}\n"
            f"📌 Тип: {sub_type}\n"
            f"💰 Сумма: {amount} руб\n"
            f"📆 Действует до: {new_end.strftime('%Y-%m-%d %H:%M')}"
        )
        
        try:
            await telethon_bot.send_message(
                uid, 
                f"✅ Вам выдана подписка **{sub_type}** на {days} дней!\n"
                f"📆 Действует до: {new_end.strftime('%Y-%m-%d %H:%M')}"
            )
        except:
            pass

@telethon_bot.on(events.CallbackQuery(data=b"cancel_subscription"))
async def cancel_sub_cb(event):
    await event.respond("❌ Выдача подписки отменена")


def init_database():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        first_name TEXT,
        registered_at TEXT,
        subscription_end TEXT,
        subscription_type TEXT DEFAULT 'BETA',
        has_subscription INTEGER DEFAULT 0,
        total_paid INTEGER DEFAULT 0,
        trial_used INTEGER DEFAULT 0,
        is_banned INTEGER DEFAULT 0,
        checked_channels INTEGER DEFAULT 0,
        referrer_id INTEGER DEFAULT 0,
        referral_count INTEGER DEFAULT 0
    )''')
    
    c.execute("PRAGMA table_info(users)")
    columns = [col[1] for col in c.fetchall()]
    
    if 'referral_count' not in columns:
        c.execute("ALTER TABLE users ADD COLUMN referral_count INTEGER DEFAULT 0")
    if 'referrer_id' not in columns:
        c.execute("ALTER TABLE users ADD COLUMN referrer_id INTEGER DEFAULT 0")
    if 'checked_channels' not in columns:
        c.execute("ALTER TABLE users ADD COLUMN checked_channels INTEGER DEFAULT 0")
    
    c.execute('''CREATE TABLE IF NOT EXISTS sessions (
        user_id INTEGER PRIMARY KEY,
        session_string TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS groups (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        group_id INTEGER,
        group_username TEXT,
        group_title TEXT,
        group_type TEXT DEFAULT 'group'
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS send_history (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        group_name TEXT,
        sent_at TEXT,
        message_text TEXT,
        message_hash TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS payments (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        amount INTEGER,
        days INTEGER,
        status TEXT,
        created_at TEXT,
        payment_type TEXT DEFAULT 'ruble',
        charge_id TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS scheduled_sends (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        groups TEXT,
        message TEXT,
        scheduled_at TEXT,
        interval_hours INTEGER,
        next_run TEXT,
        active INTEGER DEFAULT 1
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS referrals (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        referrer_id INTEGER,
        referred_id INTEGER,
        created_at TEXT
    )''')
    conn.commit()
    conn.close()
    print("✅ База данных готова")

def init_sponsors():
    if not os.path.exists(SPONSORS_FILE):
        with open(SPONSORS_FILE, "w") as f:
            json.dump([], f)

def init_required_channels():
    if not os.path.exists(REQUIRED_CHANNELS_FILE):
        with open(REQUIRED_CHANNELS_FILE, "w") as f:
            json.dump([], f)

def get_sponsors():
    try:
        with open(SPONSORS_FILE, "r") as f:
            return json.load(f)
    except:
        return []

def add_sponsor(link):
    s = get_sponsors()
    if link not in s:
        s.append(link)
        with open(SPONSORS_FILE, "w") as f:
            json.dump(s, f)
        return True
    return False

def remove_sponsor(link):
    s = get_sponsors()
    if link in s:
        s.remove(link)
        with open(SPONSORS_FILE, "w") as f:
            json.dump(s, f)
        return True
    return False

def get_required_channels():
    try:
        with open(REQUIRED_CHANNELS_FILE, "r") as f:
            return json.load(f)
    except:
        return []

def add_required_channel(channel):
    channels = get_required_channels()
    if channel not in channels:
        channels.append(channel)
        with open(REQUIRED_CHANNELS_FILE, "w") as f:
            json.dump(channels, f)
        return True
    return False

def remove_required_channel(channel):
    channels = get_required_channels()
    if channel in channels:
        channels.remove(channel)
        with open(REQUIRED_CHANNELS_FILE, "w") as f:
            json.dump(channels, f)
        return True
    return False

def register_user(user_id, username, first_name, referrer_id=None):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT user_id FROM users WHERE user_id = ?", (user_id,))
    if not c.fetchone():
        c.execute("""INSERT INTO users 
                    (user_id, username, first_name, registered_at, has_subscription, checked_channels, referrer_id) 
                    VALUES (?, ?, ?, ?, ?, ?, ?)""",
                  (user_id, username or "", first_name or "", datetime.now().isoformat(), 0, 0, referrer_id or 0))
        conn.commit()
        
        if referrer_id:
            c.execute("INSERT INTO referrals (referrer_id, referred_id, created_at) VALUES (?, ?, ?)",
                      (referrer_id, user_id, datetime.now().isoformat()))
            c.execute("UPDATE users SET referral_count = referral_count + 1 WHERE user_id = ?", (referrer_id,))
            conn.commit()
            
            try:
                conn2 = sqlite3.connect(DB_PATH)
                c2 = conn2.cursor()
                c2.execute("SELECT subscription_type FROM users WHERE user_id = ?", (referrer_id,))
                sub_type = c2.fetchone()
                current_type = sub_type[0] if sub_type and sub_type[0] else "BETA"
                
                c2.execute("SELECT subscription_end FROM users WHERE user_id = ?", (referrer_id,))
                r = c2.fetchone()
                if r and r[0]:
                    current = datetime.fromisoformat(r[0])
                    if datetime.now() < current:
                        new_end = current + timedelta(days=REFERRAL_BONUS_DAYS)
                    else:
                        new_end = datetime.now() + timedelta(days=REFERRAL_BONUS_DAYS)
                else:
                    new_end = datetime.now() + timedelta(days=REFERRAL_BONUS_DAYS)
                
                c2.execute("""UPDATE users 
                             SET subscription_end = ?, 
                                 has_subscription = 1,
                                 subscription_type = ?
                             WHERE user_id = ?""",
                          (new_end.isoformat(), current_type, referrer_id))
                conn2.commit()
                conn2.close()
            except Exception as e:
                print(f"❌ Ошибка начисления бонуса рефереру: {e}")
            
            try:
                conn2 = sqlite3.connect(DB_PATH)
                c2 = conn2.cursor()
                c2.execute("SELECT subscription_end FROM users WHERE user_id = ?", (user_id,))
                r = c2.fetchone()
                if r and r[0]:
                    current = datetime.fromisoformat(r[0])
                    if datetime.now() < current:
                        new_end = current + timedelta(days=REFERRAL_BONUS_DAYS)
                    else:
                        new_end = datetime.now() + timedelta(days=REFERRAL_BONUS_DAYS)
                else:
                    new_end = datetime.now() + timedelta(days=REFERRAL_BONUS_DAYS)
                
                c2.execute("""UPDATE users 
                             SET subscription_end = ?, 
                                 has_subscription = 1,
                                 subscription_type = 'BETA'
                             WHERE user_id = ?""",
                          (new_end.isoformat(), user_id))
                conn2.commit()
                conn2.close()
            except Exception as e:
                print(f"❌ Ошибка начисления бонуса новому пользователю: {e}")
            
            try:
                telethon_bot.loop.create_task(telethon_bot.send_message(referrer_id, 
                    f"🎉 По вашей реферальной ссылке зарегистрировался новый пользователь!\n"
                    f"👤 @{username or user_id}\n"
                    f"🎁 Вам начислен бонус {REFERRAL_BONUS_DAYS} день подписки!\n"
                    f"📊 Всего приглашений: {get_referral_count(referrer_id)}"))
            except:
                pass
            
            try:
                telethon_bot.loop.create_task(telethon_bot.send_message(user_id, 
                    f"🎁 Вы зарегистрировались по реферальной ссылке!\n"
                    f"🎁 Вам начислен бонус {REFERRAL_BONUS_DAYS} день подписки!"))
            except:
                pass
                
        conn.close()
        return True
    conn.close()
    return False

def check_subscription(user_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT subscription_end, has_subscription, is_banned FROM users WHERE user_id = ?", (user_id,))
    r = c.fetchone()
    conn.close()
    if r and r[2]:
        return False
    if r and r[1] and r[0]:
        end = datetime.fromisoformat(r[0])
        if datetime.now() < end:
            return True
    return False

def get_subscription_type(user_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT subscription_type FROM users WHERE user_id = ?", (user_id,))
    r = c.fetchone()
    conn.close()
    return r[0] if r else "BETA"

def activate_beta_subscription(user_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    end = datetime.now() + timedelta(days=FREE_TRIAL_DAYS)
    c.execute("""UPDATE users 
                 SET subscription_end = ?, 
                     has_subscription = 1, 
                     subscription_type = 'BETA',
                     trial_used = 1 
                 WHERE user_id = ?""",
              (end.isoformat(), user_id))
    conn.commit()
    conn.close()
    return True

def extend_subscription(user_id, days, amount, payment_type="ruble", charge_id=None, sub_type=None):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT subscription_end, subscription_type FROM users WHERE user_id = ?", (user_id,))
    r = c.fetchone()
    if r and r[0]:
        current = datetime.fromisoformat(r[0])
        if datetime.now() < current:
            new_end = current + timedelta(days=days)
        else:
            new_end = datetime.now() + timedelta(days=days)
    else:
        new_end = datetime.now() + timedelta(days=days)
    
    if sub_type:
        final_type = sub_type
    else:
        final_type = r[1] if r and r[1] else "BETA"
    
    c.execute("""UPDATE users 
                 SET subscription_end = ?, 
                     has_subscription = 1, 
                     subscription_type = ?,
                     total_paid = total_paid + ? 
                 WHERE user_id = ?""",
              (new_end.isoformat(), final_type, amount, user_id))
    conn.commit()
    conn.close()
    return new_end


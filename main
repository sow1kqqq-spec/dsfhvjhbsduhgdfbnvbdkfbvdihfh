@telethon_bot.on(events.CallbackQuery(func=lambda e: e.data.startswith(b"star_")))
async def star_choice_cb(event):
    uid = event.sender_id
    action = event.data.decode()
    key = action.replace("star_", "")
    
    if key == "custom":
        return
    
    if key not in STAR_PRICES:
        await event.answer("❌ Ошибка", alert=True)
        return
    
    days = STAR_PRICES[key]["days"]
    stars = STAR_PRICES[key]["stars"]
    days_text = "🔥 НАВСЕГДА" if days == 9999 else f"{days} дней"
    
    prices = [LabeledPrice(label="XTR", amount=stars)]
    
    await event.respond(
        f"⏳ Открываю окно оплаты...\n\n"
        f"📅 {days_text}\n"
        f"⭐ Стоимость: {stars} звезд"
    )
    
    try:
        await aiogram_bot.send_invoice(
            chat_id=uid,
            title=f"Подписка на {days_text}",
            description=f"Доступ ко всем функциям на {days_text}!\n⭐ Стоимость: {stars} звезд",
            payload=f"subscription_{days}_days_{stars}",
            provider_token="",
            currency="XTR",
            prices=prices,
            reply_markup=get_payment_keyboard()
        )
    except Exception as e:
        await event.respond(f"❌ Ошибка: {str(e)[:100]}")

@telethon_bot.on(events.CallbackQuery(data=b"star_custom"))
async def star_custom_cb(event):
    uid = event.sender_id
    await event.respond(
        "✏️ Введите количество дней (от 1 до 9999):\n\n"
        "⭐ Цена: дни * 5 звезд\n"
        "🔥 Навсегда = 700 звезд",
        buttons=[[Button.inline("❌ Отмена", b"cancel_payment")]]
    )
    user_states[uid] = {"action": "star_custom_days"}

@telethon_bot.on(events.NewMessage(func=lambda e: e.sender_id in user_states and user_states.get(e.sender_id, {}).get("action") == "star_custom_days"))
async def process_star_custom_days(event):
    uid = event.sender_id
    
    try:
        days = int(event.text.strip())
        if days < 1 or days > 9999:
            await event.respond("❌ От 1 до 9999 дней!")
            return
        
        stars = 700 if days >= 9999 else days * 5
        days_text = "🔥 НАВСЕГДА" if days >= 9999 else f"{days} дней"
        
        if uid in user_states:
            del user_states[uid]
        
        prices = [LabeledPrice(label="XTR", amount=stars)]
        
        await event.respond(
            f"⏳ Открываю окно оплаты...\n\n"
            f"📅 {days_text}\n"
            f"⭐ Стоимость: {stars} звезд"
        )
        
        await aiogram_bot.send_invoice(
            chat_id=uid,
            title=f"Подписка на {days_text}",
            description=f"Доступ ко всем функциям на {days_text}!\n⭐ Стоимость: {stars} звезд",
            payload=f"subscription_{days}_days_{stars}",
            provider_token="",
            currency="XTR",
            prices=prices,
            reply_markup=get_payment_keyboard()
        )
    except ValueError:
        await event.respond("❌ Введите число!")

